# Workspace do agente (onde memory/, skills/, etc vivem)
WORKSPACE_DIR=/root/.openclaw/workspace
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json

# Evolution API (WhatsApp)
# Instância dedicada ao seu número, exposta em HTTPS
EVOLUTION_BASE_URL=https://your-evolution.example.com
EVOLUTION_INSTANCE=Your Instance Name
EVOLUTION_API_KEY=

# Slack bot (precisa de scopes: chat:write, chat:write.public, channels:read,
# channels:join, files:write, reactions:read, users:read, groups:read)
SLACK_BOT_TOKEN=xoxb-
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_OWNER_USER_ID=U0XXXXXXXXX

# Owner (você) — usado pra criar invite e identificar autor do calendar
OWNER_NAME=Your Name
OWNER_EMAIL=you@yourorg.com
OWNER_EMAIL_DOMAIN=@yourorg.com

# Opcional: recepção/sala física (se você marca reuniões presenciais e o prédio
# precisa do invite pra reservar sala). Deixa vazio se não aplicar.
OFFICE_RECEPTION_EMAIL=
OFFICE_ADDRESS=

# Google Calendar via gog (substitua se for usar outra stack)
GOG_KEYRING_PASSWORD=
